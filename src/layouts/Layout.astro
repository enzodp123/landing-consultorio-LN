          d="M16 0C7.163 0 0 7.163 0 16c0 2.826.737 5.48 2.027 7.789L0 32l8.418-2.004A15.934 15.934 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.77-1.852l-.486-.289-5.002 1.19 1.227-4.865-.317-.5A13.293 13.293 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.293-9.955c-.4-.2-2.364-1.166-2.73-1.3-.366-.133-.632-.2-.9.2-.266.4-1.033 1.3-1.266 1.566-.233.267-.466.3-.866.1-.4-.2-1.687-.622-3.214-1.982-1.188-1.059-1.99-2.367-2.224-2.767-.233-.4-.025-.616.175-.815.18-.178.4-.466.6-.7.2-.233.267-.4.4-.666.133-.267.067-.5-.033-.7-.1-.2-.9-2.166-1.233-2.966-.324-.78-.655-.674-.9-.686l-.766-.013c-.267 0-.7.1-1.066.5-.366.4-1.4 1.366-1.4 3.332s1.433 3.866 1.633 4.132c.2.267 2.82 4.304 6.833 6.033.955.412 1.7.658 2.28.843.957.305 1.83.262 2.518.159.768-.115 2.364-.966 2.697-1.9.333-.933.333-1.733.233-1.9-.1-.166-.366-.266-.766-.466z"
