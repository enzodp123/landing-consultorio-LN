---
const imagesRecord = import.meta.glob(
  "../../assets/images/obrasSociales/*.{webp,png,jpg,svg,jpeg}",
  { eager: true },
);
const obrasSociales = Object.entries(imagesRecord).map(
  ([path, img]: [string, any]) => {
    // Extract filename without extension to use as alt text
    const name =
      path.split("/").pop()?.split(".")[0]?.replace(/-/g, " ") || "Obra Social";
    return {
      name: name,
      img: img.default,
    };
  },
);
---

<section
  class="w-full bg-white py-16 flex flex-col items-center justify-center border-t border-gray-100 overflow-hidden"
>
  <h2
    class="text-xs md:text-sm font-bold text-[#A3B1BB] uppercase tracking-[0.15em] mb-12 text-center px-4"
  >
    Trabajamos con las principales coberturas
  </h2>

  <div class="relative flex items-center w-full overflow-hidden">
    <!-- Fade edges -->
    <div
      class="absolute inset-y-0 left-0 w-16 md:w-32 bg-linear-to-r from-white to-transparent z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute inset-y-0 right-0 w-16 md:w-32 bg-linear-to-l from-white to-transparent z-10 pointer-events-none"
    >
    </div>

    <div class="flex animate-marquee whitespace-nowrap group">
      <!-- First set of logos -->
      <div class="flex items-center shrink-0">
        {
          obrasSociales.map((cobertura) => (
            <div class="flex items-center justify-center px-6 md:px-12 w-[160px] md:w-[220px]">
              <img
                src={cobertura.img.src}
                alt={`Logo de ${cobertura.name}`}
                class="max-h-12 md:max-h-16 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
      <!-- Second set of logos (duplicated for infinite effect) -->
      <div class="flex items-center shrink-0">
        {
          obrasSociales.map((cobertura) => (
            <div class="flex items-center justify-center px-6 md:px-12 w-[160px] md:w-[220px]">
              <img
                src={cobertura.img.src}
                alt={`Logo de ${cobertura.name}`}
                class="max-h-12 md:max-h-16 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    /* 50s duration for a smooth sliding speed, adjust as needed */
    animation: marquee 50s linear infinite;
    /* ensure it takes up enough width */
    width: max-content;
  }

  /* Pause on hover if desired - commented by default to let it keep sliding */
  /* .group:hover .animate-marquee {
    animation-play-state: paused;
  } */
</style>
