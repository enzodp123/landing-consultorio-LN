---
import { Image } from "astro:assets";
import galeria1 from "../../assets/images/galeria-1.jpg";
import galeria2 from "../../assets/images/galeria-2.jpg";
import galeria3 from "../../assets/images/galeria-3.jpg";
---

<section class="py-16 md:py-24 bg-white overflow-hidden">
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto">
    <h2
      class="text-2xl md:text-3xl lg:text-4xl font-bold text-slate-800 mb-12 md:mb-16"
    >
      Rehabilitación pensada para <span class="text-[#00BFA5]"
        >tu cuerpo, tu ritmo y tu vida.</span
      >
    </h2>

    {/* Gallery Container */}
    <div class="relative w-full">
      {
        /* 
        Mobile: Horizontal scroll snapping 
        Desktop: Grid with 3 columns 
      */
      }
      <div
        id="rehab-gallery-container"
        class="flex md:grid md:grid-cols-3 gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbars pb-8 md:pb-0"
      >
        {/* Image 1 */}
        <div
          class="min-w-[85vw] md:min-w-0 snap-center shrink-0 relative rounded-3xl overflow-hidden aspect-4/5 shadow-sm"
        >
          <Image
            src={galeria1}
            alt="Rehabilitación paciente 1"
            class="w-full h-full object-cover"
            width={600}
            height={750}
          />
        </div>

        {/* Image 2 */}
        <div
          class="min-w-[85vw] md:min-w-0 snap-center shrink-0 relative rounded-3xl overflow-hidden aspect-4/5 shadow-sm"
        >
          <Image
            src={galeria2}
            alt="Rehabilitación paciente 2"
            class="w-full h-full object-cover"
            width={600}
            height={750}
          />
        </div>

        {/* Image 3 */}
        <div
          class="min-w-[85vw] md:min-w-0 snap-center shrink-0 relative rounded-3xl overflow-hidden aspect-4/5 shadow-sm"
        >
          <Image
            src={galeria3}
            alt="Rehabilitación paciente 3"
            class="w-full h-full object-cover"
            width={600}
            height={750}
          />
        </div>
      </div>

      {
        /* Pagination Dots (Mobile primarily, optional on desktop if you want a slider effect later) */
      }
      <div
        class="flex justify-center items-center gap-2 mt-8 md:hidden"
        id="rehab-pagination"
      >
        {
          /* These dots can be updated by JS if we want, currently static structure */
        }
        <button
          aria-label="Slide 1"
          class="w-2.5 h-2.5 rounded-full bg-[#00BFA5] transition-colors rehab-dot"
        ></button>
        <button
          aria-label="Slide 2"
          class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors rehab-dot"
        ></button>
        <button
          aria-label="Slide 3"
          class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors rehab-dot"
        ></button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbars::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbars {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>

<script>
  // Simple intersection observer to update dots on scroll
  const container = document.getElementById("rehab-gallery-container");
  const dots = document.querySelectorAll(".rehab-dot");

  if (container && dots.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Find index of the intersecting element
            const children = Array.from(container.children);
            const index = children.indexOf(entry.target as Element);

            // Update dots
            if (index !== -1 && dots[index]) {
              dots.forEach((d) => {
                d.classList.remove("bg-[#00BFA5]");
                d.classList.add("bg-slate-300");
              });
              dots[index].classList.remove("bg-slate-300");
              dots[index].classList.add("bg-[#00BFA5]");
            }
          }
        });
      },
      {
        root: container,
        threshold: 0.6, // Element is considered visible when 60% is in view
      },
    );

    // Observe all images
    Array.from(container.children).forEach((child) => {
      observer.observe(child);
    });

    // Add click event to dots to scroll to image
    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        const targetElement = container.children[index] as HTMLElement;
        if (targetElement) {
          // Calculate offset relative to the container for smooth scrolling
          const scrollLeft = targetElement.offsetLeft - container.offsetLeft;
          container.scrollTo({
            left: scrollLeft,
            behavior: "smooth",
          });
        }
      });
    });
  }
</script>
