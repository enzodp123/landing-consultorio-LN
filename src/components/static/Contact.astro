---
import { Image } from "astro:assets";
import contactoImg from "../../assets/images/contacto-img.jpg";
// Note: If you have SVGs for the icons (clock, whatsapp, map pin), you can import them here.
// For now, using simple HTML entities/emojis or inline SVG as placeholders.
---

<section
  id="contacto"
  class="py-16 md:py-24 bg-white border-t border-slate-100"
>
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto">
    {/* Headings */}
    <div class="mb-12 md:mb-16">
      <h3
        class="text-[#00BFA5] font-bold tracking-wider text-sm md:text-base uppercase mb-2"
      >
        ENCONTRANOS
      </h3>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-800 font-['Poppins',sans-serif]"
      >
        Ubicación y Contacto
      </h2>
    </div>

    {/* Main Graphic / Form Container */}
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 mb-16">
      {/* Left side: Image */}
      <div class="w-full lg:w-1/2">
        <div
          class="rounded-[2.5rem] overflow-hidden h-[350px] md:h-[450px] lg:h-full lg:min-h-[400px]"
        >
          <Image
            src={contactoImg}
            alt="Detalle de consultorio con adornos"
            class="w-full h-full object-cover"
            width={624}
            height={697}
          />
        </div>
      </div>

      {/* Right side: Form */}
      <div class="w-full lg:w-1/2">
        <div
          class="bg-[#f0f9ff] rounded-[2.5rem] p-8 md:p-12 h-full flex flex-col justify-center"
        >
          <h3
            class="text-2xl md:text-3xl font-bold text-slate-800 mb-8 font-['Poppins',sans-serif]"
          >
            Consulta por una sesión en <br class="hidden md:block" />
            <span class="text-[#00BFA5]">consultorio gratis</span>
          </h3>

          <form class="space-y-6" action="#" method="POST">
            <div class="flex flex-col lg:flex-row gap-6">
              {/* Nombre Completa */}
              <div class="w-full lg:w-1/2">
                <label
                  for="nombre"
                  class="block text-sm font-semibold text-slate-700 mb-2"
                  >Nombre Completo</label
                >
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Juan"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#00BFA5] focus:ring-1 focus:ring-[#00BFA5] transition-colors bg-white font-medium text-slate-600"
                />
              </div>

              {/* Obra Social */}
              <div class="w-full lg:w-1/2">
                <label
                  for="obrasocial"
                  class="block text-sm font-semibold text-slate-700 mb-2"
                  >Obra Social</label
                >
                <input
                  type="text"
                  id="obrasocial"
                  name="obrasocial"
                  placeholder="Osde"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#00BFA5] focus:ring-1 focus:ring-[#00BFA5] transition-colors bg-white font-medium text-slate-600"
                />
              </div>
            </div>

            {/* Email */}
            <div>
              <label
                for="email"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                placeholder="micorreo@gmail.com"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#00BFA5] focus:ring-1 focus:ring-[#00BFA5] transition-colors bg-white font-medium text-slate-600"
              />
            </div>

            {/* Teléfono */}
            <div>
              <label
                for="telefono"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Teléfono</label
              >
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+54 341 ..."
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#00BFA5] focus:ring-1 focus:ring-[#00BFA5] transition-colors bg-white font-medium text-slate-600"
              />
            </div>

            {/* Mensaje */}
            <div>
              <label
                for="mensaje"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Mensaje</label
              >
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                placeholder="Hola, quisiera consultar por..."
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#00BFA5] focus:ring-1 focus:ring-[#00BFA5] transition-colors bg-white font-medium text-slate-600 resize-none"
              ></textarea>
            </div>

            {/* Submit Button */}
            <button
              type="submit"
              class="w-full bg-[#00BFA5] hover:bg-teal-500 text-white font-bold py-4 px-8 rounded-xl transition-colors text-lg"
            >
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>

    {/* Info Icons Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 mb-16">
      {/* Horarios */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-[#e0f7fa] rounded-full flex items-center justify-center shrink-0 text-[#00BFA5]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-800 text-lg">Horarios</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            Lun - Vie: 08:00 - 20:00
          </p>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            Sáb: 09:00 - 13:00
          </p>
        </div>
      </div>

      {/* WhatsApp */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-[#e0f7fa] rounded-full flex items-center justify-center shrink-0 text-[#00BFA5]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.265-3.965-6.861-6.861l1.293-.97c.362-.271.527-.733.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
            ></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-800 text-lg">WhatsApp</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            +543415711087
          </p>
          <a
            href="https://wa.me/543415711087"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-500 font-medium text-sm hover:underline"
            >Iniciar chat</a
          >
        </div>
      </div>

      {/* Dirección */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-[#e0f7fa] rounded-full flex items-center justify-center shrink-0 text-[#00BFA5]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-800 text-lg">Dirección</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            9 de Julio 1918
          </p>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            Rosario, Argentina
          </p>
        </div>
      </div>
    </div>
    
    <div
      class="w-full rounded-[2.5rem] overflow-hidden shadow-sm h-[400px] bg-slate-100 flex items-center justify-center border border-slate-200"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3347.9726344080127!2d-60.6513736!3d-32.9517319!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b7ab13542a7947%3A0x4451b79068174903!2s9%20de%20Julio%201918%2C%20S2000%20Rosario%2C%20Santa%20Fe!5e0!3m2!1ses-419!2sar!4v1773017121220!5m2!1ses-419!2sar"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen={true}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación en Google Maps"></iframe>
    </div>
  </div>
</section>
