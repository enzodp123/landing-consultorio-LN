---
import { Image } from "astro:assets";
import contactoImg from "../../assets/images/contacto-img.jpg";
// Note: If you have SVGs for the icons (clock, whatsapp, map pin), you can import them here.
// For now, using simple HTML entities/emojis or inline SVG as placeholders.
---

<section
  id="contacto"
  class="py-10 md:py-14 bg-white border-t border-slate-100"
>
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto">
    {/* Headings */}
    <div class="mb-8 md:mb-10">
      <h3
        class="text-primario font-bold tracking-wider text-sm md:text-base uppercase mb-2"
      >
        ENCONTRANOS
      </h3>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-titulos font-['Poppins',sans-serif]"
      >
        Ubicación y Contacto
      </h2>
    </div>

    {/* Main Graphic / Form Container */}
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8 mb-10">
      {/* Left side: Image */}
      <div class="reveal w-full lg:w-1/2">
        <div
          class="rounded-[2.5rem] overflow-hidden h-[250px] md:h-[300px] lg:h-full"
        >
          <Image
            src={contactoImg}
            alt="Detalle de consultorio con adornos"
            class="w-full h-[250px] md:h-[300px] lg:h-[70vh] object-cover"
            width={624}
            height={697}
          />
        </div>
      </div>

      {/* Right side: Form */}
      <div class="reveal delay-200 w-full lg:w-1/2">
        <div
          class="bg-fondo rounded-[2.5rem] p-6 md:p-8 flex flex-col justify-center lg:h-[70vh]"
        >
          <h3
            class="text-xl md:text-2xl font-bold text-titulos mb-5 font-['Poppins',sans-serif]"
          >
            Envíanos tu consulta por
            <span class="text-primario">Acá</span>
          </h3>

          <form id="contact-form" class="space-y-4">

            <div class="flex flex-col lg:flex-row gap-4">
              {/* Nombre Completa */}
              <div class="w-full lg:w-1/2">
                <label
                  for="nombre"
                  class="block text-xs font-semibold text-slate-700 mb-1"
                  >Nombre Completo</label
                >
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Juan"
                  required
                  class="w-full px-3 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-primario focus:ring-1 focus:ring-primario transition-colors bg-white font-medium text-slate-600 text-sm"
                />
              </div>

              {/* Obra Social Custom Dropdown */}
              <div class="w-full lg:w-1/2">
                <label
                  for="obrasocial"
                  class="block text-xs font-semibold text-slate-700 mb-1"
                  >Obra Social</label
                >
                <div class="custom-dropdown-container relative group" id="obras-container">
                  <input
                    type="text"
                    id="obrasocial"
                    name="obrasocial"
                    autocomplete="off"
                    placeholder="Buscá tu obra social..."
                    class="w-full px-3 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-primario focus:ring-1 focus:ring-primario transition-all bg-white font-medium text-slate-600 text-sm pr-10"
                  />
                  {/* Custom Arrow Icon */}
                  <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 group-focus-within:text-primario transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                  
                  {/* Suggestion List */}
                  <ul 
                    id="custom-obras-list" 
                    class="dropdown-list absolute left-0 right-0 mt-2 bg-white/95 backdrop-blur-sm border border-slate-100 rounded-2xl shadow-xl max-h-60 overflow-y-auto hidden z-[100] scroll-smooth"
                  >
                    {["IAPOS", "AVALIAN", "CAJA FORENSE", "FEDERADA", "UNION PERSONAL", "JERARQUICOS SALUD", "SANCOR", "OSPAC", "PODER JUDICIAL", "CIENCIAS ECONÓMICAS", "BRITÁNICA SALUD", "FEDERACIÓN MEDICA", "IOSFA", "O.S.P.S.A", "AMUR", "SADAIC", "ENERGIA SALUD", "CAJA DE INGENIEROS", "LUIS PASTEUR", "TELEVISIÓN", "OSPESGA", "SUTIAGA", "GALENO ART"].map(obra => (
                      <li 
                        class="dropdown-item px-4 py-2.5 hover:bg-primario/10 hover:text-primario cursor-pointer font-medium text-slate-600 text-sm transition-all first:rounded-t-2xl last:rounded-b-2xl"
                        data-value={obra}
                      >
                        {obra}
                      </li>
                    ))}
                    <li id="no-results" class="no-results px-4 py-3 text-sm text-slate-400 italic hidden">No se encontraron resultados</li>
                  </ul>
                </div>
              </div>

              <style>
                /* Scrollbar styling for the list */
                .dropdown-list::-webkit-scrollbar {
                  width: 6px;
                }
                .dropdown-list::-webkit-scrollbar-track {
                  background: transparent;
                }
                .dropdown-list::-webkit-scrollbar-thumb {
                  background: #e2e8f0;
                  border-radius: 10px;
                }
                .dropdown-list::-webkit-scrollbar-thumb:hover {
                  background: #cbd5e1;
                }
                
                /* Animation for the list */
                .custom-dropdown-container.open .dropdown-list {
                  display: block;
                  animation: dropdownFadeIn 0.2s ease-out;
                }

                @keyframes dropdownFadeIn {
                  from { opacity: 0; transform: translateY(-10px); }
                  to { opacity: 1; transform: translateY(0); }
                }

                /* Highlight active item during keyboard navigation if needed later */
                .obra-item-active {
                  background-color: rgba(0, 150, 136, 0.1) !important;
                  color: #009688 !important;
                }
              </style>

            </div>

            {/* Email */}
            <div>
              <label
                for="email"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                placeholder="micorreo@gmail.com"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-primario focus:ring-1 focus:ring-primario transition-colors bg-white font-medium text-slate-600"
              />
            </div>

            {/* Teléfono */}
            <div>
              <label
                for="telefono"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Teléfono</label
              >
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+54 341 ..."
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-primario focus:ring-1 focus:ring-primario transition-colors bg-white font-medium text-slate-600"
              />
            </div>

            {/* Mensaje */}
            <div>
              <label
                for="mensaje"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Mensaje</label
              >
              <textarea
                id="mensaje"
                name="mensaje"
                rows="3"
                placeholder="Hola, quisiera consultar por..."
                required
                class="w-full px-3 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-primario focus:ring-1 focus:ring-primario transition-colors bg-white font-medium text-slate-600 text-sm resize-none"
              ></textarea>
            </div>

            {/* Submit Button */}
            <div class="flex flex-col gap-3">
              <button
                id="main-wsp-submit"
                type="button"
                class="w-full bg-primario hover:bg-teal-500 text-white font-bold py-3 px-6 rounded-xl transition-colors text-base"
              >
                Enviar Mensaje
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    {/* Info Icons Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 mb-16">
      {/* Horarios */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-primario-100 rounded-full flex items-center justify-center shrink-0 text-primario"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-titulos text-lg">Horarios</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            Lun - Sáb: 09:00 - 20:00 hs
          </p>
        </div>
      </div>

      {/* WhatsApp */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-primario-100 rounded-full flex items-center justify-center shrink-0 text-primario"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.265-3.965-6.861-6.861l1.293-.97c.362-.271.527-.733.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
            ></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-titulos text-lg">WhatsApp</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            +543415711087
          </p>
          <a
            href="https://wa.me/543415711087"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-500 font-medium text-sm hover:underline"
            >Iniciar chat</a
          >
        </div>
      </div>

      {/* Dirección */}
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-primario-100 rounded-full flex items-center justify-center shrink-0 text-primario"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-titulos text-lg">Dirección</h4>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            9 de Julio 1918
          </p>
          <p class="text-slate-600 font-medium text-sm lg:text-base">
            Rosario, Argentina
          </p>
        </div>
      </div>
    </div>

    <div
      id="ubicacion"
      class="w-full rounded-[2.5rem] overflow-hidden shadow-sm h-[400px] bg-slate-100 flex items-center justify-center border border-slate-200"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3347.9726344080127!2d-60.6513736!3d-32.9517319!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b7ab13542a7947%3A0x4451b79068174903!2s9%20de%20Julio%201918%2C%20S2000%20Rosario%2C%20Santa%20Fe!5e0!3m2!1ses-419!2sar!4v1773017121220!5m2!1ses-419!2sar"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen={true}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación en Google Maps"></iframe>
    </div>
  </div>
</section>

<script>
  // --- Custom Dropdown Search Logic & Keyboard Nav ---
  const obraInput = document.getElementById("obrasocial") as HTMLInputElement;
  const dropdownContainer = document.querySelector(".custom-dropdown-container");
  const obrasItems = document.querySelectorAll(".dropdown-item");
  const noResults = document.querySelector(".no-results") as HTMLElement;

  let activeIndex = -1;

  if (obraInput) {
    // Open on focus
    obraInput.addEventListener("focus", () => {
      dropdownContainer?.classList.add("open");
      filterObras();
    });

    // Filter on input
    obraInput.addEventListener("input", filterObras);

    // Select option logic
    obrasItems.forEach(item => {
      item.addEventListener("click", () => selectOption(item as HTMLElement));
    });

    // Close on blur (delayed to allow click)
    obraInput.addEventListener("blur", () => {
      setTimeout(() => dropdownContainer?.classList.remove("open"), 200);
    });

    // Keyboard navigation
    obraInput.addEventListener("keydown", (e) => {
      const visibleItems = Array.from(obrasItems).filter(i => (i as HTMLElement).style.display !== "none") as HTMLElement[];
      
      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (!dropdownContainer?.classList.contains("open")) {
          dropdownContainer?.classList.add("open");
        } else {
          activeIndex = (activeIndex + 1) % visibleItems.length;
          updateActiveItem(visibleItems);
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIndex = (activeIndex - 1 + visibleItems.length) % visibleItems.length;
        updateActiveItem(visibleItems);
      } else if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        selectOption(visibleItems[activeIndex]);
      } else if (e.key === "Escape") {
        dropdownContainer?.classList.remove("open");
        obraInput.blur();
      }
    });

    function updateActiveItem(items: HTMLElement[]) {
      obrasItems.forEach(i => i.classList.remove("bg-slate-100"));
      if (items[activeIndex]) {
        items[activeIndex].classList.add("bg-slate-100");
        items[activeIndex].scrollIntoView({ block: "nearest" });
      }
    }

    function selectOption(item: HTMLElement) {
      obraInput.value = item.dataset.value || "";
      dropdownContainer?.classList.remove("open");
      obraInput.blur();
    }

    function filterObras() {
      const query = obraInput.value.toLowerCase().trim();
      let hasMatch = false;
      activeIndex = -1; // Reset active on filter

      obrasItems.forEach((item) => {
        const text = (item as HTMLElement).dataset.value?.toLowerCase() || "";
        if (text.includes(query)) {
          (item as HTMLElement).style.display = "block";
          hasMatch = true;
        } else {
          (item as HTMLElement).style.display = "none";
        }
        item.classList.remove("bg-slate-100");
      });

      if (noResults) noResults.style.display = hasMatch ? "none" : "block";
      if (!dropdownContainer?.classList.contains("open") && query !== "") {
        dropdownContainer?.classList.add("open");
      }
    }
  }

  // --- WhatsApp Redirection ---
  const submitBtn = document.getElementById("main-wsp-submit");
  if (submitBtn) {
    submitBtn.addEventListener("click", () => {
      const nombre    = (document.getElementById("nombre")     as HTMLInputElement)?.value.trim();
      const obraSocial= (document.getElementById("obrasocial") as HTMLInputElement)?.value.trim();
      const email     = (document.getElementById("email")      as HTMLInputElement)?.value.trim();
      const telefono  = (document.getElementById("telefono")   as HTMLInputElement)?.value.trim();
      const mensaje   = (document.getElementById("mensaje")    as HTMLTextAreaElement)?.value.trim();

      if (!nombre || !mensaje) {
        alert("Por favor completá al menos tu nombre y el mensaje.");
        return;
      }

      const lines = [
        "👋 *Nueva consulta desde la web*",
        "",
        `👤 *Nombre:* ${nombre}`,
        obraSocial ? `🏥 *Obra Social:* ${obraSocial}` : null,
        email      ? `📧 *Email:* ${email}`             : null,
        telefono   ? `📱 *Teléfono:* ${telefono}`       : null,
        "",
        `💬 *Mensaje:*\n${mensaje}`,
      ].filter(l => l !== null).join("\n");

      const url = `https://wa.me/543415711087?text=${encodeURIComponent(lines)}`;
      window.open(url, "_blank", "noopener,noreferrer");
    });
  }
</script>
