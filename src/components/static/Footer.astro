---
import { Image } from "astro:assets";
// Replace with the actual logo import path if different
import logo from "../../assets/icons/logoLNblanco.svg";
---

<footer class="bg-[#f4faff] pt-12 pb-8 border-t border-slate-100 mt-auto">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      {/* Footer Logo */}
      <div class="flex items-center">
        <!-- Using the original header logo or a text placeholder -->
        <!-- Note: Replace `logo` with the dark version of your logo if this SVG is white -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="bg-[#00BFA5] p-2 rounded shrink-0">
            <span class="text-white font-bold text-xl leading-none block"
              >LN</span
            >
          </div>
          <span
            class="text-slate-800 font-bold text-xl group-hover:text-[#00BFA5] transition-colors leading-none tracking-tight"
            >Kinesiología</span
          >
        </a>
      </div>

      {/* Copyright */}
      <div class="text-slate-500 font-medium text-xs md:text-sm text-center">
        &copy; {new Date().getFullYear()} Binadevs. Todos los derechos reservados.
      </div>

      {/* Social Links */}
      <div class="flex items-center gap-6">
        <a
          href="#"
          class="text-slate-600 hover:text-[#00BFA5] transition-colors"
          aria-label="Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-facebook"
            ><path
              d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path></svg
          >
        </a>
        <a
          href="#"
          class="text-slate-600 hover:text-[#00BFA5] transition-colors"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-instagram"
            ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              x2="17.51"
              y1="6.5"
              y2="6.5"></line></svg
          >
        </a>
      </div>
    </div>
  </div>
</footer>
