---
import logo from "../../assets/icons/logo-LN.svg";

const navItems = [
  { label: "Servicios", href: "#servicios" },
  { label: "Turno Online", href: "#turno-online" },
  { label: "Ubicación", href: "#ubicacion" },
  { label: "Galeria", href: "#galeria" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="flex w-full h-22.5 bg-bg sticky top-0 z-50 transition-shadow">
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto">
    <nav class="flex flex-row items-center justify-between py-6">
      <div class="flex flex-row items-center">
        <img src={logo.src} alt="Logo de Kinesiología LN" class="w-12" />
        <span class="font-bold text-xl pl-2 text-title">Kinesiología</span>
      </div>
      <ul class="hidden xl:flex flex-row items-center gap-8">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-text hover:text-secondary transition-colors font-medium"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href="/turno"
        class="hidden xl:flex items-center justify-center bg-secondary rounded-lg px-6 py-2.5 text-base font-bold text-white whitespace-nowrap"
      >
        Reservar Turno
      </a>

      {/* Mobile Hamburger Button */}
      <button
        id="mobile-menu-btn"
        class="xl:hidden flex flex-col justify-center items-center w-8 h-8 focus:outline-none"
        aria-label="Toggle mobile menu"
      >
        <span
          class="bg-secondary block transition-all duration-300 ease-out h-[3px] w-6 rounded-sm -translate-y-1.5"
          id="line1"></span>
        <span
          class="bg-secondary block transition-all duration-300 ease-out h-[3px] w-6 rounded-sm opacity-100"
          id="line2"></span>
        <span
          class="bg-secondary block transition-all duration-300 ease-out h-[3px] w-6 rounded-sm translate-y-1.5"
          id="line3"></span>
      </button>
    </nav>
  </div>

  {/* Mobile Menu Overlay */}
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-bg z-40 transform translate-x-full transition-transform duration-300 ease-in-out xl:hidden pt-24 pb-8 px-8 flex flex-col justify-between"
  >
    <button
      id="close-menu-btn"
      class="absolute top-6 right-[5%] sm:right-[10%] w-8 h-8 flex items-center justify-center text-secondary focus:outline-none"
      aria-label="Close mobile menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2.5"
        stroke="currentColor"
        class="w-8 h-8"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <ul class="flex flex-col gap-6 mt-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-2xl font-bold text-secondary hover:text-[#00BFA5] transition-colors mobile-link"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="mt-auto">
      <a
        href="https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig"
        class="block w-full bg-secondary text-center rounded-lg px-6 py-4 text-lg font-bold text-white shadow-md active:scale-95 transition-transform"
      >
        Reservar Turno
      </a>
    </div>
  </div>
</header>

<script>
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("close-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const line1 = document.getElementById("line1");
  const line2 = document.getElementById("line2");
  const line3 = document.getElementById("line3");

  const toggleMenu = () => {
    const isMenuOpen = !mobileMenu?.classList.contains("translate-x-full");

    // Toggle menu
    mobileMenu?.classList.toggle("translate-x-full");
    document.body.classList.toggle("overflow-hidden");

    // Animate hamburger to X
    if (!isMenuOpen) {
      line1?.classList.replace("-translate-y-1.5", "translate-y-0");
      line1?.classList.add("rotate-45");
      line2?.classList.replace("opacity-100", "opacity-0");
      line3?.classList.replace("translate-y-1.5", "translate-y-0");
      line3?.classList.add("-rotate-45");
    } else {
      line1?.classList.remove("rotate-45");
      line1?.classList.replace("translate-y-0", "-translate-y-1.5");
      line2?.classList.replace("opacity-0", "opacity-100");
      line3?.classList.remove("-rotate-45");
      line3?.classList.replace("translate-y-0", "translate-y-1.5");
    }
  };

  mobileBtn?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", toggleMenu);

  // Close menu when clicking a link
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (!mobileMenu?.classList.contains("translate-x-full")) {
        toggleMenu();
      }
    });
  });
</script>
