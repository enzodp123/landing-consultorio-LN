---
import logo from "../../assets/icons/logo-LN.svg";

const navItems = [
  { label: "Servicios", href: "#" },
  { label: "Sobre mi", href: "#" },
  { label: "Ubicación", href: "#" },
  { label: "Galeria", href: "#" },
  { label: "Contacto", href: "#" },
];
---

<header class="flex w-full h-22.5 bg-bg sticky top-0 z-50 transition-shadow">
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto">
    <nav class="flex flex-row items-center justify-between py-6">
      <div class="flex flex-row items-center">
        <img src={logo.src} alt="Logo de Kinesiología LN" class="w-12" />
        <span class="font-bold text-xl pl-2 text-title">Kinesiología</span>
      </div>
      <ul class="flex flex-row items-center gap-8">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-text hover:text-secondary transition-colors font-medium"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href="/turno"
        class="bg-secondary rounded-lg px-5.5 py-2.5 text-base font-bold text-white"
      >
        Reservar Turno
      </a>
    </nav>
  </div>
</header>
