  },
  {
    title: "Masajes y Terapia Manual",
    description:
      "Enfoque integral para aliviar la tensión muscular, reducir el estrés, mejorar la circulación y favorecer la relajación profunda.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig",
  },
  {
    title: "Drenaje Linfático Manual",
    description:
      "Masaje suave y especializado que estimula la circulación de la linfa, ayudando a eliminar la retención de líquidos y toxinas.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig",
  },
