---
import cardIcon from "../../assets/icons/card-icon.svg";

const kinesiologiaServices = [
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
  {
    title: "Rehabilitación Traumatológica",
    description:
      "Tratamiento especializado para recuperar la movilidad, aliviar el dolor y restaurar la función tras lesiones o cirugías.",
    link: "/turno",
  },
];

const esteticaServices = [
  {
    title: "Estética Integral",
    description:
      "Tratamientos no invasivos para mejorar tu bienestar corporal y facial con la mejor tecnología disponible.",
    link: "/turno",
  },
];
---

<section
  class="w-full bg-bg py-24 flex justify-center items-center border-t border-slate-100"
>
  <div class="w-[90%] lg:w-[75%] max-w-[1440px] mx-auto flex flex-col gap-8">
    <!-- Header -->
    <div class="mb-4">
      <span
        class="block text-sm font-bold text-text-secondary uppercase tracking-widest mb-2"
      >
        ESPECIALIDADES
      </span>
      <h2 class="text-5xl font-bold text-secondary mb-4">Servicios</h2>
      <p class="text-secondary font-medium text-lg">
        Tu bienestar es nuestra prioridad, <span class="text-text-secondary"
          >¡Cada sesión está pensada para vos!</span
        >
      </p>
      <p class="text-text text-base mt-2">
        Trabajamos con obras sociales y también de manera particular.
      </p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-8 border-b border-gray-200 mb-6">
      <button
        id="tab-kine"
        class="tab-btn pb-4 text-text-secondary font-bold text-lg border-b-2 border-text-secondary transition-colors"
      >
        Kinesiología y Rehabilitación
      </button>
      <button
        id="tab-estetica"
        class="tab-btn pb-4 text-text font-medium text-lg border-b-2 border-transparent hover:text-secondary transition-colors"
      >
        Estética y Salud
      </button>
    </div>

    <!-- Content: Kinesiología -->
    <div
      id="content-kine"
      class="grid grid-rows-3 grid-flow-col gap-4 md:gap-8 overflow-x-auto snap-x snap-mandatory hide-scrollbars pb-8"
    >
      {
        kinesiologiaServices.map((service) => (
          <div class="w-[85vw] md:w-[45vw] lg:w-[30vw] min-h-[160px] snap-start shrink-0 bg-white rounded-2xl p-6 shadow-sm flex flex-col items-start border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 relative group overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-[6px] bg-transparent transition-colors duration-300 group-hover:bg-text-secondary" />
            <div class="bg-[#E6F5F5] p-3 rounded-full mb-6">
              <img src={cardIcon.src} alt="Servicio Icon" class="w-6 h-6" />
            </div>
            <h4 class="text-xl font-bold text-secondary mb-3 leading-tight group-hover:text-text-secondary transition-colors">
              {service.title}
            </h4>
            <p class="text-text text-sm mb-6 grow leading-relaxed">
              {service.description}
            </p>
            <a
              href={service.link}
              class="text-text-secondary font-medium text-sm flex items-center gap-2 hover:opacity-80 transition-opacity mt-auto"
            >
              Reservar turno <span class="text-lg leading-none">&rarr;</span>
            </a>
          </div>
        ))
      }
    </div>

    <!-- Content: Estética -->
    <div
      id="content-estetica"
      class="hidden grid-rows-3 grid-flow-col gap-4 md:gap-8 overflow-x-auto snap-x snap-mandatory hide-scrollbars pb-8"
    >
      {
        esteticaServices.map((service) => (
          <div class="w-[85vw] md:w-[45vw] lg:w-[30vw] min-h-[160px] snap-start shrink-0 bg-white rounded-2xl p-6 shadow-sm flex flex-col items-start border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 relative group overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-[6px] bg-transparent transition-colors duration-300 group-hover:bg-text-secondary" />
            <div class="bg-[#E6F5F5] p-3 rounded-full mb-6">
              <img src={cardIcon.src} alt="Servicio Icon" class="w-6 h-6" />
            </div>
            <h4 class="text-xl font-bold text-secondary mb-3 leading-tight group-hover:text-text-secondary transition-colors">
              {service.title}
            </h4>
            <p class="text-text text-sm mb-6 flex-grow leading-relaxed">
              {service.description}
            </p>
            <a
              href={service.link}
              class="text-text-secondary font-medium text-sm flex items-center gap-2 hover:opacity-80 transition-opacity mt-auto"
            >
              Reservar turno <span class="text-lg leading-none">&rarr;</span>
            </a>
          </div>
        ))
      }
    </div>

    {/* Pagination Dots (Mobile/Tablet only) */}
    <div
      class="flex justify-center items-center gap-2 mt-4"
      id="services-pagination"
    >
      <button
        aria-label="Slide 1"
        class="w-2.5 h-2.5 rounded-full bg-[#00BFA5] transition-colors service-dot"
      ></button>
      <button
        aria-label="Slide 2"
        class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors service-dot"
      ></button>
      <button
        aria-label="Slide 3"
        class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors service-dot"
      ></button>
      <button
        aria-label="Slide 4"
        class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors service-dot hidden kine-dot"
      ></button>
      <button
        aria-label="Slide 5"
        class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors service-dot hidden kine-dot"
      ></button>
      <button
        aria-label="Slide 6"
        class="w-2.5 h-2.5 rounded-full bg-slate-300 transition-colors service-dot hidden kine-dot"
      ></button>
    </div>
  </div>
</section>

<script>
  const tabKine = document.getElementById("tab-kine");
  const tabEstetica = document.getElementById("tab-estetica");
  const contentKine = document.getElementById("content-kine");
  const contentEstetica = document.getElementById("content-estetica");
  const serviceDots = document.querySelectorAll(".service-dot");
  const kineDots = document.querySelectorAll(".kine-dot");

  // Observer setup for dots
  const updateDots = (index: number) => {
    serviceDots.forEach((d) => {
      d.classList.remove("bg-[#00BFA5]");
      d.classList.add("bg-slate-300");
    });
    if (serviceDots[index]) {
      serviceDots[index].classList.remove("bg-slate-300");
      serviceDots[index].classList.add("bg-[#00BFA5]");
    }
  };

  const setupObserver = (container: HTMLElement) => {
    // Clear old observers if needed, but for simplicity we create a new one
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const children = Array.from(container.children);
            const index = children.indexOf(entry.target as Element);
            if (index !== -1) {
              // Now we have 3 items per column; divide index by 3 to get the dot index
              updateDots(Math.floor(index / 3));
            }
          }
        });
      },
      {
        root: container,
        threshold: 0.6,
      },
    );

    Array.from(container.children).forEach((child) => {
      observer.observe(child);
    });

    // Add click to scroll functionality
    serviceDots.forEach((dot, index) => {
      // Clone and replace to remove old event listeners when switching tabs
      const newDot = dot.cloneNode(true) as HTMLElement;
      dot.parentNode?.replaceChild(newDot, dot);

      newDot.addEventListener("click", () => {
        // Target the first element of the specific column
        const targetElement = container.children[index * 3] as HTMLElement;
        if (targetElement) {
          const scrollLeft = targetElement.offsetLeft - container.offsetLeft;
          // Substract padding offset to align nicely
          container.scrollTo({
            left: scrollLeft - 16,
            behavior: "smooth",
          });
        }
      });
    });
  };

  if (tabKine && tabEstetica && contentKine && contentEstetica) {
    // Initial setup
    setupObserver(contentKine);
    kineDots.forEach((dot) => dot.classList.remove("hidden"));

    tabKine.addEventListener("click", () => {
      tabKine.className =
        "tab-btn pb-4 text-text-secondary font-bold text-lg border-b-2 border-text-secondary transition-colors";
      tabEstetica.className =
        "tab-btn pb-4 text-text font-medium text-lg border-b-2 border-transparent hover:text-secondary transition-colors";

      contentKine.classList.remove("hidden");
      contentKine.classList.add("grid");
      contentEstetica.classList.add("hidden");
      contentEstetica.classList.remove("grid");

      // We divide by 3 because there are 3 items per column
      serviceDots.forEach((dot, index) => {
        if (index < Math.ceil(contentKine.children.length / 3)) {
          dot.classList.remove("hidden");
        } else {
          dot.classList.add("hidden");
        }
      });
      contentKine.scrollTo({ left: 0 }); // reset scroll
      setTimeout(() => setupObserver(contentKine), 100);
    });

    tabEstetica.addEventListener("click", () => {
      tabEstetica.className =
        "tab-btn pb-4 text-text-secondary font-bold text-lg border-b-2 border-text-secondary transition-colors";
      tabKine.className =
        "tab-btn pb-4 text-text font-medium text-lg border-b-2 border-transparent hover:text-secondary transition-colors";

      contentEstetica.classList.remove("hidden");
      contentEstetica.classList.add("grid");
      contentKine.classList.add("hidden");
      contentKine.classList.remove("grid");

      // We divide by 3 because there are 3 items per column
      serviceDots.forEach((dot, index) => {
        if (index < Math.ceil(contentEstetica.children.length / 3)) {
          dot.classList.remove("hidden");
        } else {
          dot.classList.add("hidden");
        }
      });
      contentEstetica.scrollTo({ left: 0 }); // reset scroll
      setTimeout(() => setupObserver(contentEstetica), 100);
    });
  }
</script>
