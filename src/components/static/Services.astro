const esteticaServices = [
  {
    title: "Cosmiatría y Limpieza Facial",
    description:
      "Tratamientos no invasivos para mejorar tu bienestar corporal y facial con la mejor tecnología disponible.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig",
  },
  {
    title: "Diseño y Cuidado de Cejas",
    description:
      "Técnicas de perfilado y laminado para ordenar, fijar y resaltar la forma natural de tus cejas, dándoles mayor volumen y definición.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig",
  },
  {
    title: "Lifting de Pestañas",
    description:
      "Tratamiento que eleva y curva las pestañas naturales desde la raíz, logrando una mirada más abierta y expresiva sin necesidad de extensiones.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=igo",
  },
  {
    title: "Ondas Rusas",
    description:
      "Tratamiento no invasivo mediante impulsos eléctricos que estimula la musculatura de manera profunda para tonificar y dar firmeza.",
    link: "https://lnkinesiologia.site.agendapro.com/ar/sucursal/438392?fbclid=PAb21jcAQOyGRleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA81NjcwNjczNDMzNTI0MjcAAadiWt7qF8JpBdmFJBK6rXJBuPjxiqVf372DtFCt3j8cshG8tdU0Xp91U0xHjQ_aem_6YX3DHUA-GxBmfvKHSOxEA&utm_content=link_in_bio&utm_medium=social&utm_source=ig",
  },
];

// Group into chunks of 3 (for mobile/tablet slides)
function chunk<T>(arr: T[], size: number): T[][] {
  const result: T[][] = [];
  for (let i = 0; i < arr.length; i += size)
    result.push(arr.slice(i, i + size));
  return result;
}

const kineChunks = chunk(kinesiologiaServices, 3);
const esteticaChunks = chunk(esteticaServices, 3);
---

<section id="servicios" class="services-section">
  <div class="services-container">
    <!-- Header -->
    <div class="services-header">
      <span class="services-label">ESPECIALIDADES</span>
      <h2 class="services-title">Servicios</h2>
      <p class="services-subtitle">
        Tu bienestar es nuestra prioridad,{" "}
        <span class="services-subtitle-highlight"
          >¡Cada sesión está pensada para vos!</span
        >
      </p>
      <p class="services-description">
        Trabajamos con obras sociales y también de manera particular.
      </p>
    </div>

    <!-- Tabs -->
    <div class="services-tabs">
      <button id="tab-kine" class="tab-btn tab-active ">
        Kinesiología y Rehabilitación
      </button>
      <button id="tab-estetica" class="tab-btn tab-inactive ">
        Estética y Salud
      </button>
    </div>

    <!-- Content: Kinesiología -->
    <div id="content-kine" class="services-slider">
      {
        kineChunks.map((group) => (
          <div class="slide">
            {group.map((service) => (
              <div class="service-card">
                <div class="card-top-bar" />
                <div class="card-icon-wrapper">
                  <img
                    src={cardIcon.src}
                    alt="Servicio Icon"
                    class="card-icon"
                  />
                </div>
                <h3 class="card-title">{service.title}</h3>
                <p class="card-description">{service.description}</p>
                <a href={service.link} class="card-link">
                  Reservar turno <span>→</span>
                </a>
              </div>
            ))}
          </div>
        ))
      }
    </div>

    <!-- Content: Estética -->
    <div id="content-estetica" class="services-slider hidden">
      {
        esteticaChunks.map((group) => (
          <div class="slide">
            {group.map((service) => (
              <div class="service-card">
                <div class="card-top-bar" />
                <div class="card-icon-wrapper">
                  <img
                    src={cardIcon.src}
                    alt="Servicio Icon"
                    class="card-icon"
                  />
                </div>
                <h3 class="card-title">{service.title}</h3>
                <p class="card-description">{service.description}</p>
                <a href={service.link} class="card-link">
                  Reservar turno <span>→</span>
                </a>
              </div>
            ))}
          </div>
        ))
      }
    </div>

    <!-- Dots (mobile + tablet) -->
    <div id="services-dots" class="services-dots"></div>
  </div>
</section>

<style>
  .services-section {
    width: 100%;
    background-color: var(--color-bg, #f8fbfc);
    padding: 5rem 0;
    border-top: 1px solid #e2eaec;
    display: flex;
    justify-content: center;
  }

  .services-container {
    width: 90%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .services-container {
      width: 75%;
    }
  }

  /* ─── Header ──────────────────────────────────────────── */
  .services-header {
    text-align: left;
  }

  .services-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-secondary, #00bfa5);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .services-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-secondary, #0e2d3d);
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .services-subtitle {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-secondary, #0e2d3d);
    margin-bottom: 0.25rem;
  }

  .services-subtitle-highlight {
    color: var(--color-text-secondary, #00bfa5);
  }

  .services-description {
    font-size: 0.9rem;
    color: var(--color-text, #5a7a85);
  }

  /* ─── Tabs ────────────────────────────────────────────── */
  .services-tabs {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-bottom: 1px solid #e2eaec;
  }

  @media (min-width: 480px) {
    .services-tabs {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .tab-btn {
    padding: 0.75rem 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition:
      color 0.2s,
      border-color 0.2s;
    text-align: left;
  }

  @media (min-width: 768px) {
    .tab-btn {
      font-size: 0.95rem;
      padding: 0.75rem 0;
      padding-bottom: 1rem;
    }
  }

  .tab-active {
    color: var(--color-text-secondary, #00bfa5);
    font-weight: 700;
    border-bottom-color: var(--color-text-secondary, #00bfa5);
  }

  .tab-inactive {
    color: var(--color-text, #5a7a85);
  }

  .tab-inactive:hover {
    color: var(--color-secondary, #0e2d3d);
  }

  /* ─── Slider (mobile + tablet) ────────────────────────── */
  .services-slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 1.25rem;
  }

  .services-slider::-webkit-scrollbar {
    display: none;
  }

  .services-slider.hidden {
    display: none;
  }

  .slide {
    /* Each slide = full width of the visible area */
    flex: 0 0 100%;
    width: 100%;
    max-width: 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-sizing: border-box;
  }

  /* ─── Desktop: flat 3-col grid ────────────────────────── */
  @media (min-width: 1024px) {
    .services-slider {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      overflow: visible;
      scroll-snap-type: none;
    }

    /* "Unwrap" the slides so cards sit directly in the grid */
    .slide {
      display: contents;
    }
  }

  /* ─── Card ────────────────────────────────────────────── */
  .service-card {
    position: relative;
    background: #ffffff;
    border: 1px solid #e8f0f2;
    border-radius: 1rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transition:
      box-shadow 0.3s ease,
      transform 0.3s ease;
    overflow: hidden;
    min-height: 160px;
    min-width: 0;
    box-sizing: border-box;
  }

  .service-card:hover {
    box-shadow: 0 12px 32px rgba(0, 191, 165, 0.12);
    transform: translateY(-3px);
  }

  .card-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: transparent;
    transition: background 0.3s ease;
  }

  .service-card:hover .card-top-bar {
    background: var(--color-text-secondary, #00bfa5);
  }

  .card-icon-wrapper {
    background: #e6f5f5;
    padding: 0.65rem;
    border-radius: 50%;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-secondary, #0e2d3d);
    margin-bottom: 0.6rem;
    line-height: 1.35;
    transition: color 0.2s;
    width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .service-card:hover .card-title {
    color: var(--color-text-secondary, #00bfa5);
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--color-text, #5a7a85);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex-grow: 1;
    width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary, #00bfa5);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: auto;
  }

  .card-link:hover {
    opacity: 0.75;
  }

  /* ─── Dots ────────────────────────────────────────────── */
  .services-dots {
    display: none;
    justify-content: center;
    gap: 0.5rem;
  }

  .services-dots.visible {
    display: flex;
  }

  @media (min-width: 1024px) {
    .services-dots {
      display: none !important;
    }
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #cbd5e1;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active {
    background: var(--color-text-secondary, #00bfa5);
  }
</style>

<script>
  const tabKine = document.getElementById("tab-kine")!;
  const tabEstetica = document.getElementById("tab-estetica")!;
  const contentKine = document.getElementById("content-kine") as HTMLElement;
  const contentEstetica = document.getElementById(
    "content-estetica",
  ) as HTMLElement;
  const dotsContainer = document.getElementById("services-dots")!;

  function isSmall() {
    return window.innerWidth < 1024;
  }

  function buildDots(slider: HTMLElement) {
    dotsContainer.innerHTML = "";

    if (!isSmall()) {
      dotsContainer.classList.remove("visible");
      return;
    }

    const slides = slider.querySelectorAll(".slide");
    if (slides.length <= 1) {
      dotsContainer.classList.remove("visible");
      return;
    }

    dotsContainer.classList.add("visible");

    slides.forEach((_, i) => {
      const dot = document.createElement("button");
      dot.className = "dot" + (i === 0 ? " active" : "");
      dot.setAttribute("aria-label", `Página ${i + 1}`);
      dot.addEventListener("click", () => {
        slider.scrollTo({ left: i * slider.clientWidth, behavior: "smooth" });
      });
      dotsContainer.appendChild(dot);
    });
  }

  function syncDots(slider: HTMLElement) {
    if (!isSmall()) return;
    const index = Math.round(slider.scrollLeft / slider.clientWidth);
    dotsContainer
      .querySelectorAll(".dot")
      .forEach((d, i) => d.classList.toggle("active", i === index));
  }

  function setupSlider(slider: HTMLElement) {
    slider.scrollTo({ left: 0 });
    buildDots(slider);
    slider.onscroll = () => syncDots(slider);
  }

  tabKine.addEventListener("click", () => {
    tabKine.className = "tab-btn tab-active";
    tabEstetica.className = "tab-btn tab-inactive";
    contentKine.classList.remove("hidden");
    contentEstetica.classList.add("hidden");
    setupSlider(contentKine);
  });

  tabEstetica.addEventListener("click", () => {
    tabEstetica.className = "tab-btn tab-active";
    tabKine.className = "tab-btn tab-inactive";
    contentEstetica.classList.remove("hidden");
    contentKine.classList.add("hidden");
    setupSlider(contentEstetica);
  });

  // Initial
  setupSlider(contentKine);

  window.addEventListener("resize", () => {
    const active = contentKine.classList.contains("hidden")
      ? contentEstetica
      : contentKine;
    buildDots(active);
  });
</script>
