  },
];
---

<section id="servicios" class="services-section">
  <div class="services-container">
    <!-- Header -->
    <div class="services-header reveal">
      <span class="services-label">ESPECIALIDADES</span>
      <h2 class="services-title">Servicios</h2>
      <p class="services-subtitle">
        Tu bienestar es nuestra prioridad,{" "}
        <span class="services-subtitle-highlight"
          >¡Cada sesión está pensada para vos!</span
        >
      </p>
      <p class="services-description">
        Trabajamos con obras sociales y también de manera particular.
      </p>
    </div>

    <!-- Tabs -->
    <div class="services-tabs">
      <button id="tab-kine" class="tab-btn tab-active ">
        Kinesiología y Rehabilitación
      </button>
      <button id="tab-estetica" class="tab-btn tab-inactive ">
        Estética y Salud
      </button>
    </div>

    <!-- Content: Kinesiología -->
    <div id="content-kine" class="services-list">
      {
        kinesiologiaServices.map((service, idx) => (
          <div class={`service-card reveal delay-${(idx % 3 + 1) * 100}`}>
            <div class="card-top-bar" />
            <div class="card-icon-wrapper">
              <img src={cardIcon.src} alt="Servicio Icon" class="card-icon" />
            </div>
            <h3 class="card-title">{service.title}</h3>
            <p class="card-description">{service.description}</p>
            <a href={service.link} class="card-link">
              Reservar turno <span>→</span>
            </a>
          </div>
        ))
      }
    </div>

    <!-- Content: Estética -->
    <div id="content-estetica" class="services-list hidden">
      {
        esteticaServices.map((service, idx) => (
          <div class={`service-card reveal delay-${(idx % 4 + 1) * 100}`}>
            <div class="card-top-bar" />
            <div class="card-icon-wrapper">
              <img src={cardIcon.src} alt="Servicio Icon" class="card-icon" />
            </div>
            <h3 class="card-title">{service.title}</h3>
            <p class="card-description">{service.description}</p>
            <a href={service.link} class="card-link">
              Reservar turno <span>→</span>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  :root {
    --color-primario: #09A7A3;
    --color-primario-light: #E6F7F5;
    --color-secundario: #FFFFFF;
    --color-titulos: #244568;
    --color-parrafos: #111827;
    --color-fondo: #F0F9FF;
  }

  .services-section {
    width: 100%;
    background-color: var(--color-fondo);
    padding: 5rem 0;
    border-top: 1px solid #e2eaec;
    display: flex;
    justify-content: center;
  }

  .services-container {
    width: 90%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .services-container {
      width: 75%;
    }
  }

  /* ─── Header ──────────────────────────────────────────── */
  .services-header {
    text-align: left;
  }

  .services-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primario);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .services-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-titulos, #244568);
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .services-subtitle {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-titulos, #244568);
    margin-bottom: 0.25rem;
  }

  .services-subtitle-highlight {
    color: var(--color-primario);
  }

  .services-description {
    font-size: 0.9rem;
    color: var(--color-parrafos, #111827);
  }

  /* ─── Tabs ────────────────────────────────────────────── */
  .services-tabs {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-bottom: 1px solid #e2eaec;
  }

  @media (min-width: 480px) {
    .services-tabs {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .tab-btn {
    padding: 0.75rem 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition:
      color 0.2s,
      border-color 0.2s;
    text-align: left;
  }

  @media (min-width: 768px) {
    .tab-btn {
      font-size: 0.95rem;
      padding: 0.75rem 0;
      padding-bottom: 1rem;
    }
  }

  .tab-active {
    color: var(--color-primario);
    font-weight: 700;
    border-bottom-color: var(--color-primario);
  }

  .tab-inactive {
    color: var(--color-parrafos, #111827);
  }

  .tab-inactive:hover {
    color: var(--color-titulos, #244568);
  }

  /* ─── List Layout (mobile + tablet) ──────────────────── */
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .services-list.hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .services-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  /* ─── Card ────────────────────────────────────────────── */
  .service-card {
    position: relative;
    background: var(--color-secundario);
    border: 1px solid #e8f0f2;
    border-radius: 1rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transition:
      box-shadow 0.3s ease,
      transform 0.3s ease;
    overflow: hidden;
    min-height: 180px;
    min-width: 0;
    box-sizing: border-box;
  }

  .service-card:hover {
    box-shadow: 0 12px 32px rgba(9, 167, 163, 0.12);
    transform: translateY(-3px);
  }

  .card-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: transparent;
    transition: background 0.3s ease;
  }

  .service-card:hover .card-top-bar {
    background: var(--color-primario);
  }

  .card-icon-wrapper {
    background: var(--color-primario-light);
    padding: 0.65rem;
    border-radius: 50%;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-titulos);
    margin-bottom: 0.6rem;
    line-height: 1.35;
    transition: color 0.2s;
    width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .service-card:hover .card-title {
    color: var(--color-primario);
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--color-parrafos);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex-grow: 1;
    width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primario);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: auto;
  }

  .card-link:hover {
    opacity: 0.75;
  }
</style>

<script>
  const tabKine = document.getElementById("tab-kine")!;
  const tabEstetica = document.getElementById("tab-estetica")!;
  const contentKine = document.getElementById("content-kine") as HTMLElement;
  const contentEstetica = document.getElementById("content-estetica") as HTMLElement;

  tabKine.addEventListener("click", () => {
    tabKine.className = "tab-btn tab-active";
    tabEstetica.className = "tab-btn tab-inactive";
    contentKine.classList.remove("hidden");
    contentEstetica.classList.add("hidden");
  });

  tabEstetica.addEventListener("click", () => {
    tabEstetica.className = "tab-btn tab-active";
    tabKine.className = "tab-btn tab-inactive";
    contentEstetica.classList.remove("hidden");
    contentKine.classList.add("hidden");
  });
</script>
